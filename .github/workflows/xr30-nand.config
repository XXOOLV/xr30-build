# ============================================================
# CMCC XR30 (NAND / SPI-NAND 版) - ImmortalWrt 官方仓库配置
# 分支: openwrt-24.10
# 目标(Target): mediatek
# 子目标(Subtarget): filogic
# 设备(Device): cmcc_rax3000m
#
# 说明:
#   ImmortalWrt 官方仓库目前没有单独的 "cmcc_xr30" 设备配置项。
#   XR30 SPI-NAND 版硬件 (mt7981-spim-nand-ddr4) 与
#   CMCC RAX3000M NAND 版完全兼容,统一使用 cmcc_rax3000m 配置。
#
#   该配置会一次性生成:
#     - *-squashfs-sysupgrade.itb      (系统升级镜像, NAND/eMMC通用, 基于UBI)
#     - *-nand-preloader.bin           (SPI-NAND 版 bootloader 第一阶段, XR30用)
#     - *-nand-bl31-uboot.fip          (SPI-NAND 版 U-Boot, XR30用)
#     - *-emmc-preloader.bin / *-emmc-bl31-uboot.fip (eMMC版用,XR30-NAND可忽略)
#
# 本配置为最小 diffconfig,执行 make defconfig 后会自动展开为完整 .config,
# 并按设备默认包含 mt7915 无线驱动、mt7981 固件等必要组件。
# ============================================================

CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cmcc_rax3000m=y

# ------------------------------------------------------------
# 以下为常用可选项,按需取消注释(默认保持官方"纯净"配置不开启)
# ------------------------------------------------------------

# LuCI 网页界面中文语言包
# CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
# CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
# CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y

# OpenSSH 服务端(默认已含 dropbear,通常无需额外安装)
# CONFIG_PACKAGE_openssh-server=y

# 常用工具
# CONFIG_PACKAGE_curl=y
# CONFIG_PACKAGE_htop=y
# CONFIG_PACKAGE_luci-app-ttyd=y

# 调整 overlay 分区大小(单位 MB, 默认按设备闪存自动计算, 一般无需修改)
# CONFIG_TARGET_ROOTFS_PARTSIZE=104
